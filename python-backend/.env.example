# ─── 服务器 ────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8567

# ─── 数据库（MySQL 8）──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_passage_creator
DB_USER=root
DB_PASSWORD=123456

# ─── Redis 7 ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── Session ──────────────────────────────────────────────────
# 生产环境请替换为随机长字符串（openssl rand -hex 32）
SESSION_SECRET_KEY=change-me-in-production
SESSION_MAX_AGE=2592000

# ─── 密码加密盐值 ──────────────────────────────────────────────
PASSWORD_SALT=your-password-salt

# ─── AI 模型（必填）──────────────────────────────────────────
# DeepSeek：https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# ─── 配图：Pexels（可选，启用 Pexels 图片搜索）────────────────
# https://www.pexels.com/api/
# PEXELS_API_KEY=your-pexels-api-key

# ─── 配图：腾讯云 COS（可选，启用图片实际上传）────────────────
# https://console.cloud.tencent.com/cos
# TENCENT_COS_SECRET_ID=your-cos-secret-id
# TENCENT_COS_SECRET_KEY=your-cos-secret-key
# TENCENT_COS_REGION=ap-beijing
# TENCENT_COS_BUCKET=your-bucket-name
# TENCENT_COS_DOMAIN=https://your-bucket.cos.ap-beijing.myqcloud.com

# ─── 支付：Stripe（可选，启用 VIP 会员功能）──────────────────
# https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_VIP_PRICE_ID=price_...

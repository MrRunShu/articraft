# 服务器配置
SERVER_PORT=8567
SERVER_HOST=0.0.0.0

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_passage_creator
DB_USER=root
DB_PASSWORD=123456

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Session 配置
SESSION_SECRET_KEY=your-secret-key-change-in-production
SESSION_MAX_AGE=2592000

# 密码加密盐值
PASSWORD_SALT=yupi

# DeepSeek AI（当前默认启用，到 https://platform.deepseek.com 申请）
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# DashScope AI（备用，明天配好后取消注释并同步取消 config.py 中的注释）
# DASHSCOPE_API_KEY=your-dashscope-api-key
# DASHSCOPE_MODEL=qwen-plus

# Pexels 图片搜索（后续课程第4期启用）
# PEXELS_API_KEY=your-pexels-api-key

# 腾讯云 COS（后续课程第4期启用）
# TENCENT_COS_SECRET_ID=your-cos-secret-id
